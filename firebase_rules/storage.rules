rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read for public files, write only for authenticated owners (owner id encoded in path: uploads/{uid}/...)
    match /uploads/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
