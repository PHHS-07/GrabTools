rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - allow users to read their own profile and admins to read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
                      (request.auth.uid == userId && (!request.resource.data.keys().hasAny(['trustScore']) || request.resource.data.trustScore == resource.data.trustScore))
                      || isAdmin()
                    );
    }

    // Tools - owners can create/update/delete their tools, others can read
    match /tools/{toolId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid 
                    && request.resource.data.isSuspicious == false 
                    && request.resource.data.isVerified == false
                    && request.resource.data.visibility == 'visible';
      allow update: if (request.auth != null && resource.data.ownerId == request.auth.uid 
                    && request.resource.data.isSuspicious == resource.data.isSuspicious
                    && request.resource.data.isVerified == resource.data.isVerified
                    && request.resource.data.visibility == resource.data.visibility) || isAdmin();
      allow delete: if (request.auth != null && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    // App Meta - allow authenticated users to read/update the counters for bookings
    match /app_meta/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Bookings - renters create bookings, lender/admin can update status, renter can ask for extension/return
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.lenderId || request.auth.uid == resource.data.renterId || isAdmin());
      allow create: if request.auth != null 
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.trustScore >= 40
                    && request.resource.data.renterId == request.auth.uid 
                    && request.resource.data.lenderId != request.auth.uid
                    && request.resource.data.status == 'requested';
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == resource.data.renterId && (
           (resource.data.status == 'approved' && request.resource.data.status == 'paid' && request.resource.data.paymentStatus == 'paid') ||
           (request.resource.data.status == 'cancelled') ||
           (request.resource.data.status == resource.data.status && (
             (request.resource.data.refundStatus == 'requested' && resource.data.refundStatus == 'none') ||
             (request.resource.data.refundStatus == resource.data.refundStatus)
           ))
        )) ||
        (request.auth.uid == resource.data.lenderId && (
           (resource.data.status == 'requested' && request.resource.data.status == 'approved') ||
           (resource.data.status == 'paid' && request.resource.data.status == 'verified' && request.resource.data.paymentStatus == 'verified') ||
           (resource.data.status == 'verified' && request.resource.data.status == 'completed' && (request.resource.data.proofConfidenceScore >= 50 || request.resource.data.proofSubmitted == false)) ||
           (request.resource.data.status == 'cancelled') ||
           (request.resource.data.status == resource.data.status && (
             (request.resource.data.refundStatus == 'approved' && resource.data.refundStatus == 'requested') ||
             (request.resource.data.refundStatus == 'rejected' && resource.data.refundStatus == 'requested') ||
             (request.resource.data.refundStatus == resource.data.refundStatus)
           ))
        ))
      );
      allow delete: if isAdmin();
    }

    // Disputes
    match /disputes/{disputeId} {
      allow read: if request.auth != null && (
        isAdmin() || 
        request.auth.uid == resource.data.raisedBy ||
        request.auth.uid == get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.lenderId
      );
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.raisedBy &&
        (request.auth.uid == get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.renterId ||
         request.auth.uid == get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.lenderId)
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews - only allowed after completed booking
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && 
                    request.resource.data.reviewerId == request.auth.uid &&
                    get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == 'completed';
      allow delete: if isAdmin() || request.auth.uid == resource.data.reviewerId;
    }

    // Ratings - any authenticated user can read and create their own rating
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAdmin() || request.auth.uid == resource.data.reviewerId;
    }

    // Reports - authenticated users can create, admins can read
    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'phariharasudhan2004@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
